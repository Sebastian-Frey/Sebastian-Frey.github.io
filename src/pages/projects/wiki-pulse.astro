        <canvas id="heatmap-canvas" class="w-full rounded-lg" style="height: 220px; background: #ffffff;"></canvas>
        <div id="hm-tooltip" class="absolute hidden pointer-events-none bg-white border border-slate-200 rounded-lg px-2.5 py-1.5 font-mono text-[10px] text-slate-800 shadow-lg z-10 max-w-[240px]">
