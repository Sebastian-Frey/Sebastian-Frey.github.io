  <main class="max-w-7xl mx-auto px-4 pt-24 pb-16">

    <!-- HEADER + DESCRIPTION -->
    <div class="mb-8">
      <h1 class="text-5xl md:text-7xl font-black tracking-tighter leading-none uppercase mb-4">
