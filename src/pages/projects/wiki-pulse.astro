---
import MainLayout from "../../layouts/MainLayout.astro";
const wikiWsUrl = import.meta.env.PUBLIC_WIKI_WS_URL || "ws://localhost:8000/ws";
---

<MainLayout title="Wiki Pulse — Live Dashboard">

  <!-- NAV -->
  <nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
    <div class="max-w-7xl mx-auto px-4 h-14 flex justify-between items-center font-mono text-[11px] uppercase tracking-widest">
      <a href="/" class="font-bold hover:text-blue-600 transition-colors">&larr; Sebastian Frey</a>
      <div class="hidden md:flex gap-8">
        <a href="/#about" class="hover:text-blue-600 transition-colors">About</a>
        <a href="/#projects" class="text-blue-600 font-bold">Projects</a>
        <a href="/#experience" class="hover:text-blue-600 transition-colors">Experience</a>
        <a href="/#education" class="hover:text-blue-600 transition-colors">Education</a>
      </div>
      <div class="flex items-center gap-3">
        <button id="tutorial-trigger" aria-label="Open tutorial" class="px-3 py-1.5 bg-blue-600 text-white rounded-full text-[10px] font-black tracking-[0.15em] hover:bg-slate-900 transition-all shadow-sm shadow-blue-100 cursor-pointer">
          TUTORIAL
        </button>
        <a href="https://github.com/Sebastian-Frey" target="_blank" class="text-slate-400 hover:text-slate-900 transition-colors">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.042-1.416-4.042-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
        <div id="wp-status" class="flex items-center gap-1.5 px-2.5 py-1 bg-slate-50 border border-slate-200 rounded-full text-[9px] font-bold tracking-wider">
          <span id="wp-dot" class="w-1.5 h-1.5 rounded-full bg-slate-300"></span>
          <span id="wp-status-text" class="text-slate-400">CONNECTING</span>
        </div>
      </div>
    </div>
  </nav>

  <!-- TUTORIAL MODAL -->
  <div id="tutorial-overlay" role="dialog" aria-modal="true" aria-label="Wiki Pulse tutorial" class="fixed inset-0 z-[100] bg-slate-900/60 backdrop-blur-md hidden items-center justify-center opacity-0 transition-opacity duration-300 p-4">
    <div id="tutorial-content" class="bg-white rounded-3xl shadow-2xl max-w-3xl w-full max-h-[calc(100vh-2rem)] overflow-hidden transform scale-95 transition-transform duration-300 border border-slate-100 relative flex flex-col">

      <!-- Progress bar -->
      <div class="absolute top-0 left-0 right-0 h-[3px] bg-slate-100 z-20">
        <div id="tut-progress" class="h-full bg-blue-600 transition-all duration-500" style="width: 20%"></div>
      </div>

      <!-- Close button -->
      <button id="close-tutorial" aria-label="Close tutorial" class="absolute top-4 right-4 z-30 w-8 h-8 flex items-center justify-center rounded-full bg-white/80 backdrop-blur-sm hover:bg-slate-900 hover:text-white text-slate-600 transition-colors border border-slate-200">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>

      <!-- Slides -->
      <div class="overflow-hidden">
        <div id="tut-slideshow" class="flex transition-transform duration-500 ease-in-out">

          <!-- SLIDE 01 — The Firehose -->
          <div class="tut-slide min-w-full flex flex-col">
            <div class="bg-slate-950 relative overflow-hidden" style="height: 280px;">
              <svg viewBox="0 0 600 280" class="w-full h-full" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <linearGradient id="fadeL" x1="0" x2="1" y1="0" y2="0">
                    <stop offset="0" stop-color="#020617" stop-opacity="1"/>
                    <stop offset="1" stop-color="#020617" stop-opacity="0"/>
                  </linearGradient>
                </defs>
                <!-- grid pattern -->
                <g stroke="#1e293b" stroke-width="0.5" opacity="0.5">
                  <line x1="0" y1="70" x2="600" y2="70"/>
                  <line x1="0" y1="140" x2="600" y2="140"/>
                  <line x1="0" y1="210" x2="600" y2="210"/>
                </g>
                <!-- flying article pills -->
                <g font-family="IBM Plex Mono, monospace" font-size="11" font-weight="600">
                  <g>
                    <rect x="420" y="22" width="150" height="28" rx="14" fill="#1d4ed8" opacity="0.9"/>
                    <text x="495" y="41" text-anchor="middle" fill="#ffffff">🎵 Taylor Swift</text>
                  </g>
                  <g>
                    <rect x="100" y="55" width="145" height="28" rx="14" fill="#0f766e" opacity="0.85"/>
                    <text x="172" y="74" text-anchor="middle" fill="#ffffff">⚽ Lionel Messi</text>
                  </g>
                  <g>
                    <rect x="310" y="90" width="155" height="28" rx="14" fill="#b45309" opacity="0.9"/>
                    <text x="388" y="109" text-anchor="middle" fill="#ffffff">🔭 James Webb</text>
                  </g>
                  <g>
                    <rect x="40" y="125" width="140" height="28" rx="14" fill="#1d4ed8" opacity="0.75"/>
                    <text x="110" y="144" text-anchor="middle" fill="#ffffff">🎵 The Beatles</text>
                  </g>
                  <g>
                    <rect x="440" y="155" width="140" height="28" rx="14" fill="#b45309" opacity="0.8"/>
                    <text x="510" y="174" text-anchor="middle" fill="#ffffff">🔭 Black Hole</text>
                  </g>
                  <g>
                    <rect x="230" y="190" width="160" height="28" rx="14" fill="#0f766e" opacity="0.85"/>
                    <text x="310" y="209" text-anchor="middle" fill="#ffffff">⚽ FIFA World Cup</text>
                  </g>
                  <g>
                    <rect x="70" y="225" width="130" height="28" rx="14" fill="#1d4ed8" opacity="0.7"/>
                    <text x="135" y="244" text-anchor="middle" fill="#ffffff">🎵 Beyoncé</text>
                  </g>
                  <g>
                    <rect x="400" y="225" width="160" height="28" rx="14" fill="#64748b" opacity="0.8"/>
                    <text x="480" y="244" text-anchor="middle" fill="#ffffff">📜 Roman Empire</text>
                  </g>
                </g>
                <!-- left fade overlay to imply motion -->
                <rect x="0" y="0" width="120" height="280" fill="url(#fadeL)"/>
                <!-- counter -->
                <g font-family="IBM Plex Mono, monospace">
                  <text x="20" y="30" fill="#3b82f6" font-size="10" font-weight="700" letter-spacing="2">~150 EDITS / MIN</text>
                </g>
              </svg>
            </div>
            <div class="px-8 py-6">
              <div class="flex items-center justify-between mb-3">
                <span class="text-blue-600 font-mono text-[10px] font-bold uppercase tracking-[0.3em]">Step 01</span>
                <span class="font-mono text-slate-400 text-[10px]">01 / 05</span>
              </div>
              <h3 class="text-slate-900 font-black text-2xl uppercase tracking-tight mb-2">The Firehose</h3>
              <p class="text-slate-500 font-mono text-xs leading-relaxed">
                Wikipedia gets edited <strong class="text-slate-800">~150 times every minute</strong>. Each edit is an article — about music, sports, space, history, anything. How do we make sense of this stream?
              </p>
            </div>
          </div>

          <!-- SLIDE 02 — Fingerprints -->
          <div class="tut-slide min-w-full flex flex-col">
            <div class="bg-slate-950 relative overflow-hidden" style="height: 280px;">
              <svg viewBox="0 0 600 280" class="w-full h-full" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
                <!-- Three articles with fingerprint bars -->
                <g font-family="IBM Plex Mono, monospace" font-size="11" font-weight="600">
                  <!-- Row 1: Taylor Swift -->
                  <rect x="30" y="35" width="140" height="30" rx="15" fill="#1d4ed8"/>
                  <text x="100" y="54" text-anchor="middle" fill="#ffffff">🎵 Taylor Swift</text>
                  <path d="M 175 50 L 215 50" stroke="#64748b" stroke-width="1.5" fill="none" stroke-dasharray="2 3"/>
                  <polygon points="215,46 223,50 215,54" fill="#64748b"/>
                  <!-- fingerprint bars (pattern A) -->
                  <g transform="translate(230, 38)">
                    <rect x="0" y="0" width="18" height="24" fill="#3b82f6"/>
                    <rect x="20" y="0" width="18" height="12" fill="#3b82f6" opacity="0.5"/>
                    <rect x="40" y="0" width="18" height="22" fill="#3b82f6" opacity="0.9"/>
                    <rect x="60" y="0" width="18" height="8" fill="#3b82f6" opacity="0.4"/>
                    <rect x="80" y="0" width="18" height="20" fill="#3b82f6" opacity="0.8"/>
                    <rect x="100" y="0" width="18" height="14" fill="#3b82f6" opacity="0.6"/>
                    <rect x="120" y="0" width="18" height="24" fill="#3b82f6"/>
                    <rect x="140" y="0" width="18" height="10" fill="#3b82f6" opacity="0.5"/>
                    <rect x="160" y="0" width="18" height="22" fill="#3b82f6" opacity="0.9"/>
                    <rect x="180" y="0" width="18" height="6" fill="#3b82f6" opacity="0.3"/>
                    <rect x="200" y="0" width="18" height="18" fill="#3b82f6" opacity="0.75"/>
                    <text x="240" y="18" fill="#64748b" font-size="10">…</text>
                  </g>
                  <text x="230" y="82" fill="#64748b" font-size="9">Fingerprint A · 384 numbers</text>

                  <!-- Row 2: Beyoncé -->
                  <rect x="30" y="115" width="140" height="30" rx="15" fill="#1d4ed8"/>
                  <text x="100" y="134" text-anchor="middle" fill="#ffffff">🎵 Beyoncé</text>
                  <path d="M 175 130 L 215 130" stroke="#64748b" stroke-width="1.5" fill="none" stroke-dasharray="2 3"/>
                  <polygon points="215,126 223,130 215,134" fill="#64748b"/>
                  <!-- fingerprint bars (similar to A) -->
                  <g transform="translate(230, 118)">
                    <rect x="0" y="0" width="18" height="22" fill="#3b82f6" opacity="0.9"/>
                    <rect x="20" y="0" width="18" height="14" fill="#3b82f6" opacity="0.6"/>
                    <rect x="40" y="0" width="18" height="24" fill="#3b82f6"/>
                    <rect x="60" y="0" width="18" height="10" fill="#3b82f6" opacity="0.5"/>
                    <rect x="80" y="0" width="18" height="18" fill="#3b82f6" opacity="0.75"/>
                    <rect x="100" y="0" width="18" height="16" fill="#3b82f6" opacity="0.65"/>
                    <rect x="120" y="0" width="18" height="22" fill="#3b82f6" opacity="0.9"/>
                    <rect x="140" y="0" width="18" height="12" fill="#3b82f6" opacity="0.55"/>
                    <rect x="160" y="0" width="18" height="24" fill="#3b82f6"/>
                    <rect x="180" y="0" width="18" height="8" fill="#3b82f6" opacity="0.4"/>
                    <rect x="200" y="0" width="18" height="20" fill="#3b82f6" opacity="0.8"/>
                    <text x="240" y="18" fill="#64748b" font-size="10">…</text>
                  </g>
                  <text x="230" y="162" fill="#22c55e" font-size="9" font-weight="700">≈ A · very similar pattern</text>

                  <!-- Row 3: Black Hole -->
                  <rect x="30" y="195" width="140" height="30" rx="15" fill="#b45309"/>
                  <text x="100" y="214" text-anchor="middle" fill="#ffffff">🔭 Black Hole</text>
                  <path d="M 175 210 L 215 210" stroke="#64748b" stroke-width="1.5" fill="none" stroke-dasharray="2 3"/>
                  <polygon points="215,206 223,210 215,214" fill="#64748b"/>
                  <!-- fingerprint bars (different pattern) -->
                  <g transform="translate(230, 198)">
                    <rect x="0" y="0" width="18" height="8" fill="#f97316" opacity="0.4"/>
                    <rect x="20" y="0" width="18" height="22" fill="#f97316" opacity="0.9"/>
                    <rect x="40" y="0" width="18" height="14" fill="#f97316" opacity="0.6"/>
                    <rect x="60" y="0" width="18" height="24" fill="#f97316"/>
                    <rect x="80" y="0" width="18" height="6" fill="#f97316" opacity="0.3"/>
                    <rect x="100" y="0" width="18" height="20" fill="#f97316" opacity="0.85"/>
                    <rect x="120" y="0" width="18" height="10" fill="#f97316" opacity="0.5"/>
                    <rect x="140" y="0" width="18" height="18" fill="#f97316" opacity="0.75"/>
                    <rect x="160" y="0" width="18" height="4" fill="#f97316" opacity="0.25"/>
                    <rect x="180" y="0" width="18" height="24" fill="#f97316"/>
                    <rect x="200" y="0" width="18" height="12" fill="#f97316" opacity="0.55"/>
                    <text x="240" y="18" fill="#64748b" font-size="10">…</text>
                  </g>
                  <text x="230" y="242" fill="#f97316" font-size="9" font-weight="700">≠ A · very different pattern</text>
                </g>
              </svg>
            </div>
            <div class="px-8 py-6">
              <div class="flex items-center justify-between mb-3">
                <span class="text-blue-600 font-mono text-[10px] font-bold uppercase tracking-[0.3em]">Step 02</span>
                <span class="font-mono text-slate-400 text-[10px]">02 / 05</span>
              </div>
              <h3 class="text-slate-900 font-black text-2xl uppercase tracking-tight mb-2">Turn words into numbers</h3>
              <p class="text-slate-500 font-mono text-xs leading-relaxed">
                Every article gets a <strong class="text-slate-800">384-number fingerprint</strong> (an embedding). The trick: articles about similar topics get similar-looking fingerprints. Nobody tells the model what "music" means — it learns from reading billions of sentences.
              </p>
            </div>
          </div>

          <!-- SLIDE 03 — Clustering -->
          <div class="tut-slide min-w-full flex flex-col">
            <div class="bg-slate-950 relative overflow-hidden" style="height: 280px;">
              <svg viewBox="0 0 600 280" class="w-full h-full" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
                <!-- soft cluster halos -->
                <ellipse cx="160" cy="110" rx="70" ry="55" fill="#1d4ed8" opacity="0.15"/>
                <ellipse cx="420" cy="120" rx="68" ry="52" fill="#0f766e" opacity="0.18"/>
                <ellipse cx="290" cy="215" rx="72" ry="45" fill="#b45309" opacity="0.15"/>
                <!-- Music cluster dots -->
                <g fill="#3b82f6">
                  <circle cx="140" cy="95" r="6"/>
                  <circle cx="170" cy="110" r="6"/>
                  <circle cx="155" cy="135" r="6"/>
                  <circle cx="190" cy="90" r="6"/>
                  <circle cx="125" cy="125" r="6"/>
                </g>
                <!-- Sports cluster dots -->
                <g fill="#10b981">
                  <circle cx="410" cy="105" r="6"/>
                  <circle cx="440" cy="120" r="6"/>
                  <circle cx="395" cy="135" r="6"/>
                  <circle cx="425" cy="145" r="6"/>
                  <circle cx="450" cy="95" r="6"/>
                </g>
                <!-- Space cluster dots -->
                <g fill="#f97316">
                  <circle cx="275" cy="200" r="6"/>
                  <circle cx="300" cy="215" r="6"/>
                  <circle cx="285" cy="230" r="6"/>
                  <circle cx="315" cy="205" r="6"/>
                  <circle cx="260" cy="220" r="6"/>
                </g>
                <!-- Noise dots (grey, outside clusters) -->
                <g fill="#64748b" opacity="0.6">
                  <circle cx="500" cy="50" r="5"/>
                  <circle cx="70" cy="235" r="5"/>
                </g>
                <!-- Cluster labels -->
                <g font-family="IBM Plex Mono, monospace" font-weight="700">
                  <text x="160" y="50" text-anchor="middle" fill="#3b82f6" font-size="13">🎵 MUSIC</text>
                  <text x="420" y="60" text-anchor="middle" fill="#10b981" font-size="13">⚽ SPORTS</text>
                  <text x="290" y="165" text-anchor="middle" fill="#f97316" font-size="13">🔭 SPACE</text>
                </g>
                <!-- noise labels -->
                <g font-family="IBM Plex Mono, monospace" font-size="9" fill="#64748b">
                  <text x="500" y="38">noise</text>
                  <text x="70" y="223">noise</text>
                </g>
              </svg>
            </div>
            <div class="px-8 py-6">
              <div class="flex items-center justify-between mb-3">
                <span class="text-blue-600 font-mono text-[10px] font-bold uppercase tracking-[0.3em]">Step 03</span>
                <span class="font-mono text-slate-400 text-[10px]">03 / 05</span>
              </div>
              <h3 class="text-slate-900 font-black text-2xl uppercase tracking-tight mb-2">Group the similar ones</h3>
              <p class="text-slate-500 font-mono text-xs leading-relaxed">
                We let the fingerprints cluster themselves using <strong class="text-slate-800">HDBSCAN</strong> — no preset number of groups required. Articles that don't fit anywhere stay as outliers ("noise"), which is fine. Groups emerge from the data.
              </p>
            </div>
          </div>

          <!-- SLIDE 04 — 384D → 2D -->
          <div class="tut-slide min-w-full flex flex-col">
            <div class="bg-slate-950 relative overflow-hidden" style="height: 280px;">
              <svg viewBox="0 0 600 280" class="w-full h-full" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
                <!-- Left: stacked dimension bars representing 384D -->
                <g transform="translate(50, 50)">
                  <rect x="0" y="0" width="140" height="180" fill="none" stroke="#334155" stroke-width="1" rx="6"/>
                  <g font-family="IBM Plex Mono, monospace">
                    <!-- 12 stacked bar rows -->
                    <rect x="14" y="12" width="112" height="8" fill="#3b82f6" opacity="0.9"/>
                    <rect x="14" y="24" width="80" height="8" fill="#3b82f6" opacity="0.6"/>
                    <rect x="14" y="36" width="100" height="8" fill="#3b82f6" opacity="0.8"/>
                    <rect x="14" y="48" width="60" height="8" fill="#3b82f6" opacity="0.45"/>
                    <rect x="14" y="60" width="96" height="8" fill="#3b82f6" opacity="0.75"/>
                    <rect x="14" y="72" width="44" height="8" fill="#3b82f6" opacity="0.35"/>
                    <rect x="14" y="84" width="108" height="8" fill="#3b82f6" opacity="0.85"/>
                    <rect x="14" y="96" width="72" height="8" fill="#3b82f6" opacity="0.55"/>
                    <rect x="14" y="108" width="90" height="8" fill="#3b82f6" opacity="0.7"/>
                    <rect x="14" y="120" width="52" height="8" fill="#3b82f6" opacity="0.4"/>
                    <text x="70" y="144" text-anchor="middle" fill="#64748b" font-size="14" font-weight="700">⋮</text>
                    <rect x="14" y="156" width="78" height="8" fill="#3b82f6" opacity="0.55"/>
                  </g>
                  <text x="70" y="200" text-anchor="middle" fill="#3b82f6" font-family="IBM Plex Mono, monospace" font-size="11" font-weight="700">384 DIMENSIONS</text>
                  <text x="70" y="214" text-anchor="middle" fill="#64748b" font-family="IBM Plex Mono, monospace" font-size="9">impossible to visualize</text>
                </g>
                <!-- Middle: squish arrow -->
                <g transform="translate(230, 130)">
                  <path d="M 0 0 L 80 0" stroke="#3b82f6" stroke-width="2" fill="none"/>
                  <polygon points="80,-6 92,0 80,6" fill="#3b82f6"/>
                  <text x="46" y="-14" text-anchor="middle" fill="#3b82f6" font-family="IBM Plex Mono, monospace" font-size="10" font-weight="700">UMAP</text>
                  <text x="46" y="22" text-anchor="middle" fill="#64748b" font-family="IBM Plex Mono, monospace" font-size="9">preserves neighbors</text>
                </g>
                <!-- Right: 2D scatter map -->
                <g transform="translate(360, 50)">
                  <rect x="0" y="0" width="180" height="180" fill="#020617" stroke="#334155" stroke-width="1" rx="6"/>
                  <!-- clusters shown as dot blobs -->
                  <g>
                    <ellipse cx="50" cy="55" rx="28" ry="22" fill="#1d4ed8" opacity="0.2"/>
                    <circle cx="42" cy="50" r="4" fill="#3b82f6"/>
                    <circle cx="56" cy="58" r="4" fill="#3b82f6"/>
                    <circle cx="48" cy="65" r="4" fill="#3b82f6"/>
                    <circle cx="60" cy="48" r="4" fill="#3b82f6"/>
                  </g>
                  <g>
                    <ellipse cx="130" cy="60" rx="28" ry="22" fill="#0f766e" opacity="0.2"/>
                    <circle cx="122" cy="55" r="4" fill="#10b981"/>
                    <circle cx="136" cy="62" r="4" fill="#10b981"/>
                    <circle cx="128" cy="70" r="4" fill="#10b981"/>
                    <circle cx="140" cy="52" r="4" fill="#10b981"/>
                  </g>
                  <g>
                    <ellipse cx="90" cy="130" rx="32" ry="24" fill="#b45309" opacity="0.2"/>
                    <circle cx="82" cy="125" r="4" fill="#f97316"/>
                    <circle cx="96" cy="135" r="4" fill="#f97316"/>
                    <circle cx="88" cy="142" r="4" fill="#f97316"/>
                    <circle cx="100" cy="122" r="4" fill="#f97316"/>
                  </g>
                  <text x="90" y="200" text-anchor="middle" fill="#3b82f6" font-family="IBM Plex Mono, monospace" font-size="11" font-weight="700">2D MAP</text>
                  <text x="90" y="214" text-anchor="middle" fill="#64748b" font-family="IBM Plex Mono, monospace" font-size="9">what you see on screen</text>
                </g>
              </svg>
            </div>
            <div class="px-8 py-6">
              <div class="flex items-center justify-between mb-3">
                <span class="text-blue-600 font-mono text-[10px] font-bold uppercase tracking-[0.3em]">Step 04</span>
                <span class="font-mono text-slate-400 text-[10px]">04 / 05</span>
              </div>
              <h3 class="text-slate-900 font-black text-2xl uppercase tracking-tight mb-2">Squish 384D into a map</h3>
              <p class="text-slate-500 font-mono text-xs leading-relaxed">
                384 dimensions are impossible to look at. <strong class="text-slate-800">UMAP</strong> flattens them into a 2D map you can actually see — keeping articles that were neighbors in high-D close together in 2D. That's the scatter plot on the dashboard.
              </p>
            </div>
          </div>

          <!-- SLIDE 05 — Labels -->
          <div class="tut-slide min-w-full flex flex-col">
            <div class="bg-slate-950 relative overflow-hidden" style="height: 280px;">
              <svg viewBox="0 0 600 280" class="w-full h-full" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
                <!-- Word cloud on left -->
