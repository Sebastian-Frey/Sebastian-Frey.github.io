    <!-- TECH PILLS -->
    <div class="flex flex-wrap gap-2 font-mono">
      <span class="px-3 py-1.5 bg-slate-50 rounded-full text-[9px] font-bold text-slate-500 uppercase border border-slate-100">HDBSCAN</span>
      <span class="px-3 py-1.5 bg-slate-50 rounded-full text-[9px] font-bold text-slate-500 uppercase border border-slate-100">UMAP</span>
      <span class="px-3 py-1.5 bg-slate-50 rounded-full text-[9px] font-bold text-slate-500 uppercase border border-slate-100">Sentence-BERT</span>
      <span class="px-3 py-1.5 bg-slate-50 rounded-full text-[9px] font-bold text-slate-500 uppercase border border-slate-100">c-TF-IDF</span>
      <span class="px-3 py-1.5 bg-slate-50 rounded-full text-[9px] font-bold text-slate-500 uppercase border border-slate-100">Procrustes</span>
      <span class="px-3 py-1.5 bg-slate-50 rounded-full text-[9px] font-bold text-slate-500 uppercase border border-slate-100">DuckDB</span>
      <span class="px-3 py-1.5 bg-slate-50 rounded-full text-[9px] font-bold text-slate-500 uppercase border border-slate-100">Supabase</span>
      <span class="px-3 py-1.5 bg-slate-50 rounded-full text-[9px] font-bold text-slate-500 uppercase border border-slate-100">FastAPI</span>
      <span class="px-3 py-1.5 bg-slate-50 rounded-full text-[9px] font-bold text-slate-500 uppercase border border-slate-100">WebSocket</span>
      <span class="px-3 py-1.5 bg-slate-50 rounded-full text-[9px] font-bold text-slate-500 uppercase border border-slate-100">Docker</span>
      <span class="px-3 py-1.5 bg-slate-50 rounded-full text-[9px] font-bold text-slate-500 uppercase border border-slate-100">asyncio</span>
