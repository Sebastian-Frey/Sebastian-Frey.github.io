---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="BiasBreaker">
  <div class="max-w-5xl mx-auto px-6 py-24">
    <header class="mb-32">
      <h1 class="text-7xl md:text-8xl font-black tracking-tighter mb-8 uppercase">
        Bias<span class="text-blue-600">Breaker.</span>
      </h1>
      <p class="text-2xl text-slate-500 leading-relaxed max-w-3xl mb-12">
        An end-to-end AI product designed to neutralize news polarization by synthesizing balanced summaries from ideologically opposed sources.
      </p>
      <div class="flex flex-wrap gap-2 font-mono">
        {["GPT-4o", "BeautifulSoup4", "NPOV Prompting", "JSON Persistence"].map(tag => (
          <span class="px-3 py-1 bg-slate-100 text-slate-500 text-[10px] rounded border border-slate-200 uppercase">{tag}</span>
        ))}
      </div>
    </header>

    <section class="mb-40">
      <h2 class="font-mono text-[10px] font-black text-slate-400 uppercase tracking-[0.3em] mb-12 text-center underline decoration-blue-600">System Pipeline</h2>
      
      
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-16">
        <div class="group relative rounded-3xl border border-slate-200 overflow-hidden shadow-2xl bg-white">
          <img src="/images/projects/bb-output.png" alt="Synthesized Output" class="w-full h-auto" />
        </div>
        <div class="flex flex-col justify-center space-y-10">
          <div>
            <h3 class="font-bold text-xl mb-3 uppercase tracking-tight">01. Automated Extraction</h3>
            <p class="text-slate-500 text-sm leading-relaxed font-light">
              Uses <strong>BeautifulSoup4</strong> to isolate core article content from commercial boilerplate and ads.
            </p>
          </div>
          <div>
             <h3 class="font-bold text-xl mb-3 uppercase tracking-tight">02. NPOV Synthesis</h3>
             <p class="text-slate-500 text-sm leading-relaxed font-light">
               Engineered <strong>GPT-4o</strong> prompting to perform cross-article factual reconciliation and explicit source attribution.
             </p>
          </div>
        </div>
      </div>
    </section>

    <section class="max-w-4xl mx-auto border-t border-slate-100 pt-24 prose prose-slate prose-sm lg:prose-base">
       <h2 class="text-3xl font-black tracking-tight mb-12 uppercase">Technical Implementation</h2>
       
       <h3 class="font-mono text-blue-600 uppercase tracking-widest text-xs mb-4">File Structure</h3>
       <pre class="bg-slate-900 text-blue-300 p-8 rounded-2xl text-xs leading-relaxed">
<code>{`BiasBreaker/
├── app.py               # Streamlit Dashboard & Persistence
├── scraper_cnn.py       # Scraper & GPT Synthesis Logic
├── articles/            # Storage for unified .txt articles
└── saved_articles.json  # Metadata index for history gallery`}</code></pre>

       <h3 class="font-mono text-blue-600 uppercase tracking-widest text-xs mt-16 mb-4">Core Engine</h3>
       <p class="text-slate-600">
         The pipeline ensures that non-English articles are detected via <code>langdetect</code> and translated via OpenAI before being passed to the synthesis chain.
       </p>
    </section>
  </div>
</MainLayout>