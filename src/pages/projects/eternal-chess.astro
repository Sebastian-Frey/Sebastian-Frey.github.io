  </main>

  <!-- ── GLITCH CSS + ANIMATION CSS ── -->
  <style>
    .glitch-title {
      position: relative;
    }
    .glitch-title::before,
    .glitch-title::after {
      content: attr(data-text);
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
    }

    @keyframes glitch-1 {
      0%, 100% { clip-path: inset(0 0 100% 0); }
      5% { clip-path: inset(20% 0 60% 0); transform: translate(-3px, 0); }
      10% { clip-path: inset(0 0 100% 0); }
      40% { clip-path: inset(60% 0 10% 0); transform: translate(3px, 0); }
      45% { clip-path: inset(0 0 100% 0); }
    }

    @keyframes glitch-2 {
      0%, 100% { clip-path: inset(0 0 100% 0); }
      15% { clip-path: inset(40% 0 30% 0); transform: translate(3px, 0); }
      20% { clip-path: inset(0 0 100% 0); }
      55% { clip-path: inset(10% 0 70% 0); transform: translate(-3px, 0); }
      60% { clip-path: inset(0 0 100% 0); }
    }

    .glitch-title::before {
      color: #3b82f6;
      animation: glitch-1 4s infinite linear;
      opacity: 0.6;
    }
    .glitch-title::after {
      color: #ef4444;
      animation: glitch-2 4s infinite linear;
      opacity: 0.4;
    }

    /* Neon glow on active squares */
    .square-active {
      box-shadow: inset 0 0 20px rgba(59, 130, 246, 0.4), 0 0 8px rgba(59, 130, 246, 0.3);
      border: 1px solid rgba(59, 130, 246, 0.5) !important;
    }
    .square-last-move {
      box-shadow: inset 0 0 20px rgba(59, 130, 246, 0.3);
      background-color: rgba(59, 130, 246, 0.08) !important;
    }
    .square-selected {
      box-shadow: inset 0 0 25px rgba(59, 130, 246, 0.6), 0 0 12px rgba(59, 130, 246, 0.4);
      border: 1px solid rgba(59, 130, 246, 0.7) !important;
    }
    .square-legal {
      position: relative;
    }
    .square-legal::after {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 30%;
      height: 30%;
      border-radius: 50%;
      background: rgba(59, 130, 246, 0.35);
    }
    .square-check {
      box-shadow: inset 0 0 25px rgba(239, 68, 68, 0.5), 0 0 12px rgba(239, 68, 68, 0.4);
      background-color: rgba(239, 68, 68, 0.12) !important;
    }

    /* Animation overlay for sliding pieces */
    .piece-clone {
      position: fixed;
      z-index: 100;
      pointer-events: none;
      transition: transform 200ms ease-out;
    }
    .piece-hidden {
      visibility: hidden;
    }

    /* Queue bar pulse animation */
    @keyframes queue-pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.7; }
    }
    .queue-your-turn {
      animation: queue-pulse 2s ease-in-out infinite;
    }

    /* Scrollbar for dashboard panels */
    .scrollbar-thin::-webkit-scrollbar { width: 4px; }
    .scrollbar-thin::-webkit-scrollbar-track { background: transparent; }
    .scrollbar-thin::-webkit-scrollbar-thumb { background: #334155; border-radius: 2px; }
  </style>

  <!-- ── CHESS.JS CDN ── -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.10.3/chess.min.js"></script>

  <!-- ── Inject build-time WS URL ── -->
  <script define:vars={{ wsUrl }}>
    window.__EC_WS_URL = wsUrl;
  </script>

  <!-- ── GAME ENGINE (WebSocket + Queue + Animations) ── -->
  <script is:inline>
    // ── CONFIG ──
    var WS_URL = window.__EC_WS_URL || 'ws://localhost:8000/ws';

    // ── PIECE UNICODE MAP ──
    var PIECE_GLYPHS = {
      'K': '\u2654', 'Q': '\u2655', 'R': '\u2656', 'B': '\u2657', 'N': '\u2658', 'P': '\u2659',
      'k': '\u265A', 'q': '\u265B', 'r': '\u265C', 'b': '\u265D', 'n': '\u265E', 'p': '\u265F'
    };

    // ── STATE ──
    var chess = new Chess();
    var selectedSquare = null;
    var moveHistory = [];
    var socket = null;
    var reconnectAttempts = 0;
    var lastMoveSentAt = 0;
    var lastMoveFrom = null;
    var lastMoveTo = null;
    var animating = false;

    // Queue state
    var myId = null;
    var queueEnabled = false;
    var queuePosition = -1;
    var isMyTurn = true;

    // ── DOM REFS ──
    var boardEl     = document.getElementById('chess-board');
    var moveInput   = document.getElementById('move-input');
    var submitBtn   = document.getElementById('submit-move');
    var feedback    = document.getElementById('move-feedback');
    var turnEl      = document.getElementById('turn-indicator');
    var fenEl       = document.getElementById('fen-display');
    var moveNumEl   = document.getElementById('move-number');
    var resultEl    = document.getElementById('game-result');
    var pgnEl       = document.getElementById('pgn-display');
    var commitLog   = document.getElementById('commit-log');
    var pipelineEl  = document.getElementById('pipeline-status');
    var statusBadge = document.getElementById('status-badge');
    var statMoves   = document.getElementById('stat-moves');
    var statLatency = document.getElementById('stat-latency');
    var statViewers = document.getElementById('stat-viewers');
    var queueBar    = document.getElementById('queue-bar');
    var queueText   = document.getElementById('queue-text');
    var serverDownBar = document.getElementById('server-down-bar');
    var checkBanner = document.getElementById('check-banner');
    var gameOverOverlay = document.getElementById('game-over-overlay');
    var gameOverResult = document.getElementById('game-over-result');
    var voteRestartBtn = document.getElementById('vote-restart-btn');
    var voteRestartInline = document.getElementById('vote-restart-inline');
    var voteStatus  = document.getElementById('vote-status');

    // ── SOUND SYSTEM ──
    var sounds = {};
    function preloadSounds() {
      ['move', 'capture', 'check', 'notify'].forEach(function(name) {
        var audio = new Audio('/sounds/' + name + '.mp3');
        audio.preload = 'auto';
        audio.volume = 0.5;
        sounds[name] = audio;
      });
    }
    function playSound(name) {
      var s = sounds[name];
      if (s) {
        s.currentTime = 0;
        s.play().catch(function() {});
      }
    }
    preloadSounds();

    // Request notification permission
    if ('Notification' in window && Notification.permission === 'default') {
      Notification.requestPermission();
    }

    // ── WEBSOCKET CONNECTION ──
    function connectWebSocket() {
      socket = new WebSocket(WS_URL);

      socket.onopen = function() {
        reconnectAttempts = 0;
        setServerStatus('online');
        showFeedback('Connected to game server', 'emerald');
      };

      socket.onmessage = function(event) {
        var data;
        try { data = JSON.parse(event.data); } catch(e) { return; }
        handleServerMessage(data);
      };

      socket.onclose = function() {
        setServerStatus('offline');
        var delay = Math.min(1000 * Math.pow(2, reconnectAttempts), 30000);
        reconnectAttempts++;
        showFeedback('Disconnected. Reconnecting in ' + Math.round(delay/1000) + 's...', 'amber');
        setTimeout(connectWebSocket, delay);
      };

      socket.onerror = function() {
        setServerStatus('offline');
      };
    }

    // ── HANDLE SERVER MESSAGES ──
    function handleServerMessage(data) {
      var type = data.type;

      if (type === 'init') {
        if (data.fen) {
          chess = new Chess(data.fen);
        }
        if (data.moves && Array.isArray(data.moves)) {
          moveHistory = data.moves;
        }
        if (data.move_count != null) {
          statMoves.textContent = data.move_count.toLocaleString();
        }
        if (data.your_id) {
          myId = data.your_id;
        }
        lastMoveFrom = null;
        lastMoveTo = null;
        selectedSquare = null;
        // Clear game-over and check states
        gameOverOverlay.classList.add('hidden');
        checkBanner.classList.add('hidden');
        voteStatus.classList.add('hidden');
        voteRestartInline.classList.add('hidden');
        renderBoard();
        updateUI();
        renderMoveHistory(moveHistory);
        return;
      }

      if (type === 'move') {
        var fromSq = data.from || null;
        var toSq = data.to || null;

        if (fromSq && toSq && !animating) {
          // Animate the move
          animateMove(fromSq, toSq, data, function() {
            applyMoveData(data, fromSq, toSq);
          });
        } else {
          applyMoveData(data, fromSq, toSq);
        }
        return;
      }

      if (type === 'error') {
        showFeedback('Server: ' + (data.message || 'Invalid move'), 'red');
        if (data.fen) {
          chess = new Chess(data.fen);
          selectedSquare = null;
          renderBoard();
          updateUI();
        }
        return;
      }

      if (type === 'viewers') {
        if (data.count != null) {
          statViewers.innerHTML = data.count + ' <span class="text-blue-500">viewers</span>';
        }
        return;
      }

      if (type === 'queue') {
        var wasMyTurn = isMyTurn;
        queueEnabled = data.enabled;
        if (data.enabled) {
          queuePosition = data.position;
          isMyTurn = data.is_your_turn;
        } else {
          queuePosition = -1;
          isMyTurn = true;
        }
        updateQueueUI();

        // Notify when it becomes your turn
        if (data.is_your_turn && !wasMyTurn && queueEnabled) {
          playSound('notify');
          if ('Notification' in window && Notification.permission === 'granted') {
            new Notification('Eternal Chess', { body: "It's your turn to move!" });
          }
        }
        return;
      }

      if (type === 'game_over') {
        var result = data.result || 'Game Over';
        resultEl.textContent = result;
        resultEl.className = 'font-mono text-[10px] font-bold text-amber-400';
        playSound('check');
        checkBanner.classList.add('hidden');

        // Show game over overlay
        gameOverResult.textContent = result;
        gameOverOverlay.classList.remove('hidden');
        voteRestartInline.classList.add('hidden');

        // Browser notification
        if ('Notification' in window && Notification.permission === 'granted') {
          new Notification('Eternal Chess', { body: 'Game Over: ' + result });
        }
        return;
      }

      if (type === 'restart_vote') {
        voteStatus.textContent = data.votes + ' / ' + data.needed + ' votes to restart';
        voteStatus.classList.remove('hidden');
        return;
      }
    }

    // ── APPLY MOVE DATA (after animation or immediately) ──
    function applyMoveData(data, fromSq, toSq) {
      if (data.fen) {
        chess = new Chess(data.fen);
      } else if (data.move) {
        chess.move(data.move);
      }

      // Track latency if this was our own move
      if (lastMoveSentAt > 0) {
        var latency = Date.now() - lastMoveSentAt;
        statLatency.innerHTML = latency + '<span class="text-blue-500">ms</span>';
        lastMoveSentAt = 0;
      }

      if (data.move) {
        moveHistory.push(data.move);
        addMoveEntry(data.move, moveHistory.length);
      }
      if (data.move_count != null) {
        statMoves.textContent = data.move_count.toLocaleString();
      }

      // Play sound + check banner
      if (data.is_check) {
        playSound('check');
        checkBanner.classList.remove('hidden');
      } else {
        checkBanner.classList.add('hidden');
        if (data.is_capture) {
          playSound('capture');
        } else {
          playSound('move');
        }
      }

      // Show inline restart vote button during active games
      if (!chess.game_over()) {
        voteRestartInline.classList.remove('hidden');
      }

      lastMoveFrom = fromSq;
      lastMoveTo = toSq;
      selectedSquare = null;
      renderBoard();
      updateUI();
    }

    // ── MOVE ANIMATION ──
    function animateMove(fromSq, toSq, data, callback) {
      var fromEl = boardEl.querySelector('[data-square="' + fromSq + '"]');
      var toEl = boardEl.querySelector('[data-square="' + toSq + '"]');

      if (!fromEl || !toEl) {
        callback();
        return;
      }

      var pieceEl = fromEl.querySelector('span[class*="text-2xl"], span[class*="md:text-4xl"]');
      if (!pieceEl) {
        callback();
        return;
      }

      animating = true;

      var fromRect = fromEl.getBoundingClientRect();
      var toRect = toEl.getBoundingClientRect();

      // Create flying clone
      var clone = document.createElement('span');
      clone.textContent = pieceEl.textContent;
      clone.className = 'piece-clone';
      clone.style.fontSize = getComputedStyle(pieceEl).fontSize;
      clone.style.color = pieceEl.style.color;
      clone.style.textShadow = pieceEl.style.textShadow;
      clone.style.left = (fromRect.left + fromRect.width / 2) + 'px';
      clone.style.top = (fromRect.top + fromRect.height / 2) + 'px';
      clone.style.transform = 'translate(-50%, -50%)';
      document.body.appendChild(clone);

      // Hide the original piece
      pieceEl.classList.add('piece-hidden');

      // Trigger animation
      requestAnimationFrame(function() {
        var dx = toRect.left - fromRect.left;
        var dy = toRect.top - fromRect.top;
        clone.style.transform = 'translate(calc(-50% + ' + dx + 'px), calc(-50% + ' + dy + 'px))';
      });

      clone.addEventListener('transitionend', function() {
        clone.remove();
        animating = false;
        callback();
      });

      // Fallback in case transitionend doesn't fire
      setTimeout(function() {
        if (clone.parentNode) {
          clone.remove();
          animating = false;
          callback();
        }
      }, 300);
    }

    // ── QUEUE UI ──
    function updateQueueUI() {
      if (!queueEnabled) {
        queueBar.classList.add('hidden');
        // Re-enable input
        moveInput.disabled = false;
        submitBtn.disabled = false;
        submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        return;
      }

      queueBar.classList.remove('hidden');

      if (isMyTurn) {
        queueBar.className = 'px-6 py-3 border-b border-emerald-500/30 bg-emerald-500/10 font-mono text-[11px] uppercase tracking-widest text-center queue-your-turn';
        queueText.innerHTML = '<span class="text-emerald-400 font-bold">Your Turn</span> <span class="text-emerald-500/70">— Make a move!</span>';
        moveInput.disabled = false;
        submitBtn.disabled = false;
        submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
      } else {
        queueBar.className = 'px-6 py-3 border-b border-amber-500/30 bg-amber-500/10 font-mono text-[11px] uppercase tracking-widest text-center';
        queueText.innerHTML = '<span class="text-amber-400 font-bold">Position #' + (queuePosition + 1) + ' of ' + '</span><span class="text-amber-500/70"> — Wait for your turn</span>';
        moveInput.disabled = true;
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
      }
    }

    // ── SERVER STATUS INDICATOR ──
    function setServerStatus(state) {
      if (state === 'online') {
        statusBadge.className = 'px-3 py-1.5 bg-emerald-500/10 border border-emerald-500/30 rounded-full text-emerald-400 text-[9px] font-bold tracking-wider transition-all duration-300';
        statusBadge.innerHTML = '\u25CF SERVER: ONLINE';
        pipelineEl.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span> CONNECTED';
        pipelineEl.className = 'font-mono text-[10px] font-bold text-emerald-400 flex items-center gap-2';
        serverDownBar.classList.add('hidden');
      } else {
        statusBadge.className = 'px-3 py-1.5 bg-red-500/10 border border-red-500/30 rounded-full text-red-400 text-[9px] font-bold tracking-wider transition-all duration-300';
        statusBadge.innerHTML = '\u25CF SERVER: OFFLINE';
        pipelineEl.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-red-400"></span> DISCONNECTED';
        pipelineEl.className = 'font-mono text-[10px] font-bold text-red-400 flex items-center gap-2';
        serverDownBar.classList.remove('hidden');
      }
    }

    // ── SEND MOVE VIA WEBSOCKET ──
    function sendMove(san) {
      if (!socket || socket.readyState !== WebSocket.OPEN) {
        showFeedback('Not connected to server', 'red');
        return;
      }
      lastMoveSentAt = Date.now();
      socket.send(JSON.stringify({ move: san }));
    }

    // ── RENDER BOARD ──
    function renderBoard() {
      boardEl.innerHTML = '';
      var board = chess.board();

      // Determine if king is in check
      var checkSquare = null;
      if (chess.in_check && chess.in_check()) {
        // Find the king that's in check
        var turnColor = chess.turn();
        for (var r = 0; r < 8; r++) {
          for (var c = 0; c < 8; c++) {
            var p = board[r][c];
            if (p && p.type === 'k' && p.color === turnColor) {
              checkSquare = String.fromCharCode(97 + c) + (8 - r);
            }
          }
        }
      }

      for (var r = 0; r < 8; r++) {
        for (var c = 0; c < 8; c++) {
          var sq = document.createElement('div');
          var isLight = (r + c) % 2 === 0;
          var file = String.fromCharCode(97 + c);
          var rank = 8 - r;
          var sqName = file + rank;

          sq.className = 'relative flex items-center justify-center cursor-pointer transition-all duration-150 aspect-square';
          sq.style.backgroundColor = isLight ? '#1e293b' : '#0f172a';
          sq.dataset.square = sqName;

          // Rank/file labels
          if (c === 0) {
            var label = document.createElement('span');
            label.className = 'absolute top-0.5 left-1 text-[8px] font-mono font-bold pointer-events-none';
            label.style.color = isLight ? '#334155' : '#1e293b';
            label.textContent = rank.toString();
            sq.appendChild(label);
          }
          if (r === 7) {
            var label = document.createElement('span');
            label.className = 'absolute bottom-0 right-1 text-[8px] font-mono font-bold pointer-events-none';
            label.style.color = isLight ? '#334155' : '#1e293b';
            label.textContent = file;
            sq.appendChild(label);
          }

          // Last move highlight
          if (sqName === lastMoveFrom || sqName === lastMoveTo) {
            sq.classList.add('square-last-move');
          }

          // Check highlight
          if (sqName === checkSquare) {
            sq.classList.add('square-check');
          }

          // Piece
          var piece = board[r][c];
          if (piece) {
            var pieceEl = document.createElement('span');
            var key = piece.color === 'w' ? piece.type.toUpperCase() : piece.type.toLowerCase();
            pieceEl.textContent = PIECE_GLYPHS[key];
            pieceEl.className = 'text-2xl md:text-4xl pointer-events-none select-none';
            pieceEl.style.color = piece.color === 'w' ? '#ffffff' : '#475569';
            pieceEl.style.textShadow = piece.color === 'w'
              ? '0 0 10px rgba(255,255,255,0.4), 0 1px 2px rgba(0,0,0,0.3)'
              : '0 0 6px rgba(71,85,105,0.3), 0 1px 2px rgba(0,0,0,0.5)';
            sq.appendChild(pieceEl);
          }

          // Selected highlight
          if (selectedSquare === sqName) {
            sq.classList.add('square-selected');
          }

          // Legal move dots
          if (selectedSquare) {
            var moves = chess.moves({ square: selectedSquare, verbose: true });
            if (moves.some(function(m) { return m.to === sqName; })) {
              sq.classList.add('square-legal');
            }
          }

          // Click handler
          (function(name) {
            sq.addEventListener('click', function() { handleSquareClick(name); });
          })(sqName);

          boardEl.appendChild(sq);
        }
      }
    }

    // ── SQUARE CLICK ──
    function handleSquareClick(sqName) {
      // Queue guard
      if (queueEnabled && !isMyTurn) {
        showFeedback('Wait for your turn! You are #' + (queuePosition + 1) + ' in the queue.', 'amber');
        return;
      }

      if (selectedSquare) {
        var moves = chess.moves({ square: selectedSquare, verbose: true });
        var target = moves.find(function(m) { return m.to === sqName; });
        if (target) {
          executeMove(target.san);
        } else {
          var piece = chess.get(sqName);
          selectedSquare = (piece && piece.color === chess.turn()) ? sqName : null;
        }
      } else {
        var piece = chess.get(sqName);
        if (piece && piece.color === chess.turn()) {
          selectedSquare = sqName;
        }
      }
      renderBoard();
    }

    // ── EXECUTE MOVE ──
    function executeMove(san) {
      // Queue guard
      if (queueEnabled && !isMyTurn) {
        showFeedback('Wait for your turn!', 'amber');
        return;
      }

      // Optimistic local update
      var result = chess.move(san);
      if (!result) {
        showFeedback('Invalid move: ' + san, 'red');
        return;
      }
      selectedSquare = null;
      lastMoveFrom = result.from;
      lastMoveTo = result.to;
      renderBoard();
      updateUI();

      // Send to server
      sendMove(san);

      // Brief status flash
      pipelineEl.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span> SENDING';
      pipelineEl.className = 'font-mono text-[10px] font-bold text-amber-400 flex items-center gap-2';
      setTimeout(function() {
        if (socket && socket.readyState === WebSocket.OPEN) {
          pipelineEl.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span> CONNECTED';
          pipelineEl.className = 'font-mono text-[10px] font-bold text-emerald-400 flex items-center gap-2';
        }
      }, 1500);
    }

    // ── UPDATE UI ──
    function updateUI() {
      var turn = chess.turn() === 'w' ? 'WHITE' : 'BLACK';
      turnEl.textContent = turn + ' TO MOVE';
      fenEl.textContent = chess.fen();
      var fenParts = chess.fen().split(' ');
      moveNumEl.textContent = fenParts[5] || '1';

      if (chess.in_checkmate()) {
        var winner = chess.turn() === 'w' ? 'BLACK' : 'WHITE';
        resultEl.textContent = winner + ' WINS';
        resultEl.className = 'font-mono text-[10px] font-bold text-amber-400';
      } else if (chess.in_draw()) {
        resultEl.textContent = 'DRAW';
        resultEl.className = 'font-mono text-[10px] font-bold text-amber-400';
      } else {
        resultEl.textContent = 'IN PROGRESS';
        resultEl.className = 'font-mono text-[10px] font-bold text-slate-400';
      }

      // PGN
      var history = chess.history();
      if (history.length > 0) {
        var pgn = '';
        for (var i = 0; i < history.length; i += 2) {
          var num = Math.floor(i / 2) + 1;
          pgn += num + '. ' + history[i];
          if (history[i + 1]) pgn += ' ' + history[i + 1] + ' ';
          else pgn += ' ';
        }
        pgnEl.textContent = pgn.trim();
      } else {
        pgnEl.textContent = 'No moves yet \u2014 be the first to play.';
      }
    }

    // ── MOVE LOG ──
    function renderMoveHistory(moves) {
      if (!moves || moves.length === 0) {
        commitLog.innerHTML = '<div class="p-3 bg-slate-800/30 rounded-lg border border-slate-700/30 text-center"><span class="font-mono text-[10px] text-slate-500">No moves yet</span></div>';
        return;
      }
      commitLog.innerHTML = '';
      var recent = moves.slice(-20).reverse();
      recent.forEach(function(move, i) {
        var idx = moves.length - i;
        var entry = document.createElement('div');
        entry.className = 'p-3 bg-slate-800/30 rounded-lg border border-slate-700/30 hover:border-blue-500/30 transition-colors';
        var color = idx % 2 === 1 ? 'White' : 'Black';
        entry.innerHTML = '<div class="flex items-center justify-between mb-1"><span class="font-mono text-[10px] font-bold text-white">\u265F ' + move + '</span><span class="font-mono text-[9px] text-slate-600">#' + idx + '</span></div><span class="font-mono text-[9px] text-slate-500">' + color + ' \u00B7 Move ' + Math.ceil(idx / 2) + '</span>';
        commitLog.appendChild(entry);
      });
    }

    function addMoveEntry(san, idx) {
      var placeholder = commitLog.querySelector('.text-center');
      if (placeholder) placeholder.remove();

      var entry = document.createElement('div');
      entry.className = 'p-3 bg-blue-950/30 rounded-lg border border-blue-500/20 transition-colors';
      var color = idx % 2 === 1 ? 'White' : 'Black';
      entry.innerHTML = '<div class="flex items-center justify-between mb-1"><span class="font-mono text-[10px] font-bold text-blue-400">\u265F ' + san + '</span><span class="font-mono text-[9px] text-blue-500">#' + idx + '</span></div><span class="font-mono text-[9px] text-slate-500">' + color + ' \u00B7 Move ' + Math.ceil(idx / 2) + '</span>';
      commitLog.prepend(entry);

      while (commitLog.children.length > 20) {
        commitLog.removeChild(commitLog.lastChild);
      }
    }

    // ── FEEDBACK ──
    function showFeedback(msg, color) {
      var colorMap = { red: '#f87171', blue: '#60a5fa', emerald: '#34d399', amber: '#fbbf24' };
      feedback.textContent = msg;
      feedback.style.color = colorMap[color] || '#94a3b8';
      feedback.className = 'mt-3 font-mono text-xs';
      feedback.classList.remove('hidden');
      setTimeout(function() { feedback.classList.add('hidden'); }, 6000);
    }

    // ── INPUT HANDLER ──
    submitBtn.addEventListener('click', function() {
      if (queueEnabled && !isMyTurn) {
        showFeedback('Wait for your turn!', 'amber');
        return;
      }
      var san = moveInput.value.trim();
      if (!san) return;
      var result = chess.move(san);
      if (!result) {
        showFeedback('Illegal move: ' + san, 'red');
        return;
      }
      chess.undo();
      executeMove(san);
      moveInput.value = '';
    });

    moveInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') submitBtn.click();
    });

    // ── VOTE RESTART ──
    function sendVoteRestart() {
      if (!socket || socket.readyState !== WebSocket.OPEN) {
        showFeedback('Not connected to server', 'red');
        return;
      }
      socket.send(JSON.stringify({ action: 'vote_restart' }));
      showFeedback('You voted to restart the game', 'blue');
    }

    voteRestartBtn.addEventListener('click', sendVoteRestart);
    voteRestartInline.addEventListener('click', sendVoteRestart);

    // ── INIT ──
    renderBoard();
    updateUI();
    connectWebSocket();
  </script>
</MainLayout>
