---
import MainLayout from "../../layouts/MainLayout.astro";
const wsUrl = import.meta.env.PUBLIC_WS_URL || "ws://localhost:8000/ws";
---

<MainLayout title="Eternal Chess">

  <!-- ── NAV ── -->
  <nav class="fixed top-0 w-full z-50 bg-slate-950/80 backdrop-blur-md border-b border-slate-800">
    <div class="max-w-6xl mx-auto px-6 h-16 flex justify-between items-center font-mono text-[11px] uppercase tracking-widest">
      <a href="/" class="font-bold text-slate-300 hover:text-blue-400 transition-colors">← Sebastian Frey</a>
      <div class="hidden md:flex gap-8">
        <a href="/#about" class="text-slate-400 hover:text-blue-400 transition-colors">About</a>
        <a href="/#projects" class="text-blue-400 font-bold">Projects</a>
        <a href="/#experience" class="text-slate-400 hover:text-blue-400 transition-colors">Experience</a>
        <a href="/#education" class="text-slate-400 hover:text-blue-400 transition-colors">Education</a>
      </div>
      <div class="flex items-center gap-4">
        <a href="https://github.com/Sebastian-Frey" target="_blank" class="text-slate-500 hover:text-blue-400 transition-colors">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.042-1.416-4.042-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
        <div id="status-badge" class="px-3 py-1.5 bg-slate-800 border border-slate-700 rounded-full text-slate-500 text-[9px] font-bold tracking-wider transition-all duration-300">
          ● SERVER: CONNECTING
        </div>
      </div>
    </div>
  </nav>

  <!-- ── HERO ── -->
  <section class="relative min-h-[60vh] flex items-end overflow-hidden bg-slate-950">
    <!-- Grid background pattern -->
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(rgba(59,130,246,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(59,130,246,0.5) 1px, transparent 1px); background-size: 60px 60px;"></div>
    <!-- Radial glow -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(59,130,246,0.08)_0%,transparent_70%)]"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 pb-16 pt-32 w-full">
      <div class="text-blue-400 font-mono text-[10px] font-bold mb-5 uppercase tracking-[0.5em]">
        Live Multiplayer · WebSocket Architecture
      </div>
      <h1 class="text-6xl md:text-[9rem] font-black tracking-tighter leading-none uppercase text-white mb-6 glitch-title">
        ETERNAL<span class="text-blue-500">CHESS</span><span class="text-slate-600">.</span>
      </h1>
      <p class="text-slate-400 font-mono text-sm max-w-xl leading-relaxed">
        A real-time multiplayer chess game powered by <strong class="text-white">WebSockets</strong>. Server validates moves, broadcasts state to all connected players instantly. Persistent. Live. No page reloads.
      </p>
    </div>
  </section>

  <!-- ── HOW TO PLAY ── -->
  <section class="bg-slate-950 border-b border-slate-800">
    <div class="max-w-6xl mx-auto px-6 py-12">
      <div class="bg-slate-900 rounded-2xl border border-slate-800 p-8">
        <div class="flex items-center gap-3 mb-5">
          <span class="text-2xl">♟</span>
          <h2 class="font-mono text-sm font-bold text-white uppercase tracking-widest">How to Play</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 font-mono text-sm text-slate-400 leading-relaxed">
          <div>
            <p class="mb-3">This is a <strong class="text-white">shared, persistent chess game</strong>. There is one board, and everyone in the world plays on it together. The game continues even after you close your browser.</p>
            <p>Click a piece to select it, then click a destination square to move. You can also type moves in standard notation (e.g. e4, Nf3, O-O) in the input box below the board.</p>
          </div>
          <div>
            <p class="mb-3">When <strong class="text-white">1-2 people</strong> are online, anyone can make a move at any time.</p>
            <p class="mb-3">When <strong class="text-white">3 or more people</strong> are online, a queue system activates. Each person makes <strong class="text-white">one move</strong>, then goes to the back of the line. The page will notify you when it's your turn.</p>
            <p class="text-slate-500 text-xs">Your queue position is shown above the board.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── METRICS RIBBON ── -->
  <section class="bg-slate-950 border-y border-slate-800">
    <div class="max-w-6xl mx-auto px-6 py-8 grid grid-cols-2 md:grid-cols-4 gap-0 font-mono divide-x divide-slate-800">
      <div class="px-6 first:pl-0">
        <span class="block text-[10px] text-slate-500 uppercase tracking-[0.3em] mb-2">Total Moves</span>
        <span class="text-2xl font-black text-white" id="stat-moves">—</span>
      </div>
      <div class="px-6">
        <span class="block text-[10px] text-slate-500 uppercase tracking-[0.3em] mb-2">Latency</span>
        <span class="text-2xl font-black text-white" id="stat-latency">—<span class="text-blue-500">ms</span></span>
      </div>
      <div class="px-6">
        <span class="block text-[10px] text-slate-500 uppercase tracking-[0.3em] mb-2">Protocol</span>
        <span class="text-2xl font-black text-blue-400">WebSocket</span>
      </div>
      <div class="px-6">
        <span class="block text-[10px] text-slate-500 uppercase tracking-[0.3em] mb-2">Connected</span>
        <span class="text-2xl font-black text-white" id="stat-viewers">0 <span class="text-blue-500">viewers</span></span>
      </div>
    </div>
  </section>

  <!-- ── MAIN CONTENT: BOARD + DASHBOARD ── -->
  <main class="bg-slate-950 min-h-screen">
    <div class="max-w-7xl mx-auto px-6 py-20">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

        <!-- ── CHESS BOARD PANEL ── -->
        <div class="lg:col-span-7">
          <div class="bg-slate-900 rounded-2xl border border-slate-800 overflow-hidden">
            <!-- Board header -->
            <div class="px-6 py-4 border-b border-slate-800 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                <span class="font-mono text-[10px] text-slate-400 uppercase tracking-widest">Live Board</span>
              </div>
              <span class="font-mono text-[10px] text-slate-600" id="turn-indicator">WHITE TO MOVE</span>
            </div>

            <!-- Server down notice -->
            <div id="server-down-bar" class="px-6 py-4 border-b border-red-500/30 bg-red-500/5 hidden">
              <div class="flex items-center justify-center gap-3 font-mono text-[11px]">
                <span class="text-red-400 uppercase tracking-widest font-bold">Server Offline</span>
                <span class="text-slate-500">—</span>
                <span class="text-slate-400">The game server is currently down. Reach out at <a href="mailto:sc.frey@aol.de" class="text-blue-400 hover:text-blue-300 underline underline-offset-2 normal-case tracking-normal">sc.frey@aol.de</a></span>
              </div>
            </div>

            <!-- Queue bar -->
            <div id="queue-bar" class="px-6 py-3 border-b border-slate-800 font-mono text-[11px] uppercase tracking-widest text-center hidden">
              <span id="queue-text"></span>
            </div>

            <!-- Chess board -->
            <div class="p-4 md:p-8">
              <div id="chess-board" class="grid grid-cols-8 aspect-square max-w-[560px] mx-auto rounded-lg overflow-hidden border border-slate-700 shadow-2xl shadow-blue-500/5 relative">
                <!-- Board squares rendered by JS -->
              </div>
            </div>

            <!-- Check banner -->
            <div id="check-banner" class="px-6 py-2 border-b border-red-500/30 bg-red-500/10 font-mono text-[11px] uppercase tracking-widest text-center hidden">
              <span class="text-red-400 font-bold">Check!</span>
            </div>

            <!-- Game over overlay -->
            <div id="game-over-overlay" class="px-6 py-6 border-b border-amber-500/30 bg-amber-500/5 hidden">
              <div class="text-center">
                <div class="font-mono text-[10px] text-amber-500/70 uppercase tracking-[0.4em] mb-2">Game Over</div>
                <div id="game-over-result" class="font-mono text-2xl font-black text-amber-400 mb-4"></div>
                <button id="vote-restart-btn" class="px-6 py-2.5 bg-blue-600 text-white font-mono text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-blue-500 transition-all hover:shadow-lg hover:shadow-blue-500/20">
                  Vote to Restart
                </button>
                <div id="vote-status" class="font-mono text-[10px] text-slate-500 mt-3 hidden"></div>
              </div>
            </div>

            <!-- Move input -->
            <div class="px-6 pb-6">
              <div class="flex gap-3">
                <input
                  type="text"
                  id="move-input"
                  placeholder="Enter move (e.g. e4, Nf3, O-O)"
                  class="flex-1 bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-white font-mono text-sm placeholder-slate-600 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/50 transition-all"
                />
                <button
                  id="submit-move"
                  class="px-6 py-3 bg-blue-600 text-white font-mono text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-blue-500 transition-all hover:shadow-lg hover:shadow-blue-500/20"
                >
                  Dispatch
                </button>
              </div>
              <div class="flex items-center justify-between mt-3">
                <div id="move-feedback" class="font-mono text-xs hidden"></div>
                <button id="vote-restart-inline" class="font-mono text-[9px] text-slate-600 hover:text-amber-400 uppercase tracking-wider transition-colors hidden">
                  Vote to Restart
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- ── GITOPS DASHBOARD PANEL ── -->
        <div class="lg:col-span-5 space-y-6">

          <!-- Status Panel -->
          <div class="bg-slate-900 rounded-2xl border border-slate-800 p-6">
            <div class="flex items-center gap-3 mb-5">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-blue-400"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
              <span class="font-mono text-[10px] text-slate-400 uppercase tracking-widest font-bold">Live Server Telemetry</span>
            </div>
            <div class="space-y-4">
              <div class="flex items-center justify-between p-3 bg-slate-800/50 rounded-xl border border-slate-700/50">
                <span class="font-mono text-[10px] text-slate-500 uppercase">Server Status</span>
                <span id="pipeline-status" class="font-mono text-[10px] font-bold text-slate-500 flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-slate-500"></span>
                  CONNECTING
                </span>
              </div>
              <div class="flex items-center justify-between p-3 bg-slate-800/50 rounded-xl border border-slate-700/50">
                <span class="font-mono text-[10px] text-slate-500 uppercase">Current FEN</span>
                <span id="fen-display" class="font-mono text-[9px] text-blue-400 truncate max-w-[200px]">loading...</span>
              </div>
              <div class="flex items-center justify-between p-3 bg-slate-800/50 rounded-xl border border-slate-700/50">
                <span class="font-mono text-[10px] text-slate-500 uppercase">Move Number</span>
                <span id="move-number" class="font-mono text-sm font-bold text-white">—</span>
              </div>
              <div class="flex items-center justify-between p-3 bg-slate-800/50 rounded-xl border border-slate-700/50">
                <span class="font-mono text-[10px] text-slate-500 uppercase">Game Result</span>
                <span id="game-result" class="font-mono text-[10px] font-bold text-slate-400">IN PROGRESS</span>
              </div>
            </div>
          </div>

          <!-- Commit History -->
          <div class="bg-slate-900 rounded-2xl border border-slate-800 p-6">
            <div class="flex items-center gap-3 mb-5">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-blue-400"><circle cx="12" cy="12" r="4"/><line x1="1.05" y1="12" x2="7" y2="12"/><line x1="17.01" y1="12" x2="22.96" y2="12"/></svg>
              <span class="font-mono text-[10px] text-slate-400 uppercase tracking-widest font-bold">Commit History</span>
            </div>
            <div id="commit-log" class="space-y-2 max-h-[320px] overflow-y-auto scrollbar-thin">
              <!-- Populated by JS -->
              <div class="p-3 bg-slate-800/30 rounded-lg border border-slate-700/30 animate-pulse">
                <div class="h-3 bg-slate-700 rounded w-3/4 mb-2"></div>
                <div class="h-2 bg-slate-800 rounded w-1/2"></div>
              </div>
            </div>
          </div>

          <!-- Game Info -->
          <div class="bg-slate-900 rounded-2xl border border-slate-800 p-6">
            <div class="flex items-center gap-3 mb-5">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-blue-400"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              <span class="font-mono text-[10px] text-slate-400 uppercase tracking-widest font-bold">Move Log (PGN)</span>
            </div>
            <div id="pgn-display" class="font-mono text-xs text-slate-500 leading-loose bg-slate-800/30 rounded-xl p-4 border border-slate-700/30 min-h-[80px] max-h-[200px] overflow-y-auto">
              Waiting for game state...
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── WORKFLOW EXPLANATION ── -->
    <section class="border-t border-slate-800 py-28">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <div class="text-blue-400 font-mono text-[10px] font-bold mb-3 uppercase tracking-[0.4em]">System Architecture</div>
          <h2 class="text-5xl font-black tracking-tighter uppercase text-white">The WebSocket Pipeline</h2>
          <p class="text-slate-400 font-mono text-sm mt-4 max-w-2xl mx-auto leading-relaxed">
            Every chess move flows through a persistent WebSocket connection. The server validates, updates state, and broadcasts to all connected clients in real time.
          </p>
        </div>

        <!-- CSS Flowchart -->
        <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-0 max-w-5xl mx-auto">
          <!-- Step 1 -->
          <div class="flex flex-col items-center text-center w-full md:w-1/5">
            <div class="w-16 h-16 rounded-2xl bg-blue-600/10 border border-blue-500/30 flex items-center justify-center mb-4">
              <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-blue-400"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <span class="font-mono text-[10px] text-blue-400 uppercase tracking-widest font-bold block mb-1">Step 01</span>
            <span class="font-mono text-xs text-white font-bold uppercase">User Move</span>
            <span class="font-mono text-[9px] text-slate-500 mt-1">SAN notation input</span>
          </div>

          <!-- Arrow -->
          <div class="hidden md:flex items-center justify-center flex-1">
            <div class="h-[2px] flex-1 bg-gradient-to-r from-blue-500/50 to-blue-500/20"></div>
            <svg width="12" height="12" fill="currentColor" viewBox="0 0 12 12" class="text-blue-500 -ml-1"><path d="M4 1l6 5-6 5V1z"/></svg>
          </div>
          <div class="md:hidden w-[2px] h-6 bg-gradient-to-b from-blue-500/50 to-blue-500/20"></div>

          <!-- Step 2 -->
          <div class="flex flex-col items-center text-center w-full md:w-1/5">
            <div class="w-16 h-16 rounded-2xl bg-blue-600/10 border border-blue-500/30 flex items-center justify-center mb-4">
              <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-blue-400"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <span class="font-mono text-[10px] text-blue-400 uppercase tracking-widest font-bold block mb-1">Step 02</span>
            <span class="font-mono text-xs text-white font-bold uppercase">WS Send</span>
            <span class="font-mono text-[9px] text-slate-500 mt-1">socket.send(move)</span>
          </div>

          <!-- Arrow -->
          <div class="hidden md:flex items-center justify-center flex-1">
            <div class="h-[2px] flex-1 bg-gradient-to-r from-blue-500/50 to-blue-500/20"></div>
            <svg width="12" height="12" fill="currentColor" viewBox="0 0 12 12" class="text-blue-500 -ml-1"><path d="M4 1l6 5-6 5V1z"/></svg>
          </div>
          <div class="md:hidden w-[2px] h-6 bg-gradient-to-b from-blue-500/50 to-blue-500/20"></div>

          <!-- Step 3 -->
          <div class="flex flex-col items-center text-center w-full md:w-1/5">
            <div class="w-16 h-16 rounded-2xl bg-amber-600/10 border border-amber-500/30 flex items-center justify-center mb-4">
              <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-amber-400"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <span class="font-mono text-[10px] text-amber-400 uppercase tracking-widest font-bold block mb-1">Step 03</span>
            <span class="font-mono text-xs text-white font-bold uppercase">Server Validate</span>
            <span class="font-mono text-[9px] text-slate-500 mt-1">python-chess referee</span>
          </div>

          <!-- Arrow -->
          <div class="hidden md:flex items-center justify-center flex-1">
            <div class="h-[2px] flex-1 bg-gradient-to-r from-blue-500/50 to-blue-500/20"></div>
            <svg width="12" height="12" fill="currentColor" viewBox="0 0 12 12" class="text-blue-500 -ml-1"><path d="M4 1l6 5-6 5V1z"/></svg>
          </div>
          <div class="md:hidden w-[2px] h-6 bg-gradient-to-b from-blue-500/50 to-blue-500/20"></div>

          <!-- Step 4 -->
          <div class="flex flex-col items-center text-center w-full md:w-1/5">
            <div class="w-16 h-16 rounded-2xl bg-emerald-600/10 border border-emerald-500/30 flex items-center justify-center mb-4">
              <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-emerald-400"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span class="font-mono text-[10px] text-emerald-400 uppercase tracking-widest font-bold block mb-1">Step 04</span>
            <span class="font-mono text-xs text-white font-bold uppercase">Broadcast</span>
            <span class="font-mono text-[9px] text-slate-500 mt-1">WS push to all clients</span>
          </div>

          <!-- Arrow -->
          <div class="hidden md:flex items-center justify-center flex-1">
            <div class="h-[2px] flex-1 bg-gradient-to-r from-blue-500/50 to-blue-500/20"></div>
            <svg width="12" height="12" fill="currentColor" viewBox="0 0 12 12" class="text-blue-500 -ml-1"><path d="M4 1l6 5-6 5V1z"/></svg>
          </div>
          <div class="md:hidden w-[2px] h-6 bg-gradient-to-b from-blue-500/50 to-blue-500/20"></div>

          <!-- Step 5 -->
          <div class="flex flex-col items-center text-center w-full md:w-1/5">
            <div class="w-16 h-16 rounded-2xl bg-blue-600/10 border border-blue-500/30 flex items-center justify-center mb-4">
              <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-blue-400"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            <span class="font-mono text-[10px] text-blue-400 uppercase tracking-widest font-bold block mb-1">Step 05</span>
            <span class="font-mono text-xs text-white font-bold uppercase">Board Refresh</span>
            <span class="font-mono text-[9px] text-slate-500 mt-1">onmessage → render</span>
          </div>
        </div>

        <!-- Code Snippet -->
        <div class="mt-20 bg-slate-900 rounded-2xl border border-slate-800 overflow-hidden max-w-4xl mx-auto">
          <div class="px-6 py-3 border-b border-slate-800 flex items-center gap-3">
            <div class="flex gap-1.5">
              <div class="w-2.5 h-2.5 rounded-full bg-red-500/60"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-amber-500/60"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-emerald-500/60"></div>
            </div>
            <span class="font-mono text-[10px] text-slate-500">WebSocket message flow</span>
          </div>
          <pre class="p-6 font-mono text-xs text-slate-300 leading-relaxed overflow-x-auto"><code><span class="text-slate-500">// Client → Server (move)</span>
socket.send(JSON.stringify(&#123;
  <span class="text-blue-400">"move"</span>: <span class="text-amber-400">"e4"</span>
&#125;));

<span class="text-slate-500">// Server → All Clients (broadcast)</span>
&#123;
  <span class="text-blue-400">"type"</span>:  <span class="text-amber-400">"move"</span>,
  <span class="text-blue-400">"move"</span>:  <span class="text-amber-400">"e4"</span>,
  <span class="text-blue-400">"fen"</span>:   <span class="text-amber-400">"rnbqkbnr/pppppppp/8/..."</span>,
  <span class="text-blue-400">"turn"</span>:  <span class="text-amber-400">"b"</span>
&#125;</code></pre>
        </div>
      </div>
    </section>

    <!-- ── IMPLEMENTATION DETAILS ── -->
    <section class="border-t border-slate-800 py-28">
      <div class="max-w-6xl mx-auto px-6">
        <div class="mb-16">
