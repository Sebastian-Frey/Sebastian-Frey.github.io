            <pre class="p-6 font-mono text-[11px] text-slate-300 leading-relaxed overflow-x-auto max-h-[400px]"><code><span class="text-blue-400">const</span> socket = <span class="text-blue-400">new</span> WebSocket(
  <span class="text-amber-400">'ws://&#123;YOUR_SERVER&#125;:8000/ws'</span>
);

socket.<span class="text-emerald-400">onopen</span> = () =&gt; &#123;
