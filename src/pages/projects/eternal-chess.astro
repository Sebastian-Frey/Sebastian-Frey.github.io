            </div>
            <pre class="p-6 font-mono text-[11px] text-slate-300 leading-relaxed overflow-x-auto max-h-[400px]"><code><span class="text-blue-400">from</span> fastapi <span class="text-blue-400">import</span> FastAPI, WebSocket
<span class="text-blue-400">import</span> chess, json

app = FastAPI()
board = chess.Board()
clients: <span class="text-emerald-400">list</span>[WebSocket] = []

<span class="text-blue-400">@app.websocket</span>(<span class="text-amber-400">"/ws"</span>)
<span class="text-blue-400">async def</span> <span class="text-emerald-400">ws</span>(socket: WebSocket):
    <span class="text-blue-400">await</span> socket.accept()
    clients.append(socket)

    <span class="text-slate-500"># Send current state</span>
    <span class="text-blue-400">await</span> socket.send_json(&#123;
        <span class="text-amber-400">"type"</span>: <span class="text-amber-400">"init"</span>,
        <span class="text-amber-400">"fen"</span>: board.fen()
    &#125;)

    <span class="text-blue-400">async for</span> data <span class="text-blue-400">in</span> socket.iter_json():
        move = board.parse_san(data[<span class="text-amber-400">"move"</span>])
        board.push(move)
        <span class="text-blue-400">for</span> c <span class="text-blue-400">in</span> clients:
            <span class="text-blue-400">await</span> c.send_json(&#123;
                <span class="text-amber-400">"type"</span>: <span class="text-amber-400">"move"</span>,
                <span class="text-amber-400">"fen"</span>: board.fen()
            &#125;)</code></pre>
