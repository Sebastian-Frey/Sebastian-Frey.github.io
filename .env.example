# Eternal Chess
GITHUB_TOKEN=
GITHUB_REPO=Sebastian-Frey/eternal-chess
PUBLIC_WS_URL=wss://chess.itssebastianfrey.com/ws

# Wiki Pulse — server-side (VPS only)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
WIKIPULSE_DATA_DIR=/var/lib/wikipulse
WIKIPULSE_USER_AGENT=WikiPulse/0.1 (sc.frey@aol.de)
WIKIPULSE_MIN_CLUSTER_SIZE=15
WIKIPULSE_MAX_CLUSTER_ARTICLES=1200

# Wiki Pulse — frontend (injected at build time, safe to ship)
PUBLIC_WIKI_WS_URL=wss://wiki.itssebastianfrey.com/ws
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
